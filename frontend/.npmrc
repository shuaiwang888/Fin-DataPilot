# pnpm config: allow esbuild's postinstall to run (downloads native binary).
# In pnpm 10+ this is the canonical way; the package.json `pnpm.onlyBuiltDependencies`
# field works too, but .npmrc is the more universal form.
ignore-pnpmfile=false
ignore-workspace-root-check=true

# Approve esbuild postinstall without prompting
verify-deps-before-run=false
