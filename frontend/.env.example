# Vite build-time env vars. Copy to .env for local dev.

# Backend API base URL. For production set this to your deployed HF Space URL
# (e.g. https://appQQQ-FinDataPilot.hf.space — NO trailing slash).
VITE_API_BASE=

# Optional: override the base path (default is "/Fin-DataPilot/" for GitHub
# Pages project sites). Set to "/" for custom-domain or user/org root pages.
# VITE_BASE=/Fin-DataPilot/
